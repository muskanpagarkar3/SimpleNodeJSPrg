pipeline {
    agent any

    triggers {
        pollSCM('H/2 * * * *')
    }

    stages {
        stage('Install Dependencies') {
            steps {
                echo 'Installing dependencies...'
                bat 'npm install'
            }
        }

        stage('Run NodeJS Program') {
            steps {
                echo 'Running NodeJS Program...'
                bat 'node app.js'
            }
        }
    }
}